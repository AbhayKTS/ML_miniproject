# ─── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth ───────────────────────────────────────────────
# REQUIRED in production — used to sign/verify JWTs
JWT_SECRET=

# ─── Google Gemini AI ───────────────────────────────────
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Supabase (optional — falls back to JSON file store)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── CORS ───────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
